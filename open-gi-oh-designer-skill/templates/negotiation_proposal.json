      "reasons": ["{{reason1}}", "{{reason2}}"],
      "alternative_suggestions": ["{{alt1}}", "{{alt2}}"]
    },
    "request_clarification": {
      "message": "我需要更多澄清关于...",
      "questions": ["{{question1}}", "{{question2}}"]
    }
