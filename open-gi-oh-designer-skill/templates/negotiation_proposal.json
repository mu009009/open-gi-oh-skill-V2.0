    },
    "implementation_details": {
      "specific_changes": [
        "{{change1}}",
        "{{change2}}"
      ],
      "compatibility_check": "{{compatibility_note}}",
      "testing_suggestions": [
        "{{test1}}",
        "{{test2}}"
      ]
    }
  },
  "negotiation_parameters": {
    "priority_level": "{{priority}}",
    "timeframe": "{{timeframe}}",
    "success_criteria": [
      "{{criterion1}}",
      "{{criterion2}}"
    ]
  },
  "ethical_commitments": {
    "respect_design_sovereignty": true,
    "provide_rational_arguments": true,
    "open_to_counter_proposals": true,
